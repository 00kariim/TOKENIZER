# MDES TSP Simulator — Environment Variables
# Copy to .env and fill in the blanks. NEVER commit .env to source control.

# ─── Database ─────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://mdes-db:5432/mdes_vault_db
SPRING_DATASOURCE_USERNAME=mdes_user
SPRING_DATASOURCE_PASSWORD=change_me_strong_password

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Shared HMAC-SHA256 key between TSP and Core Banking — must be identical in both .env files.
# Generate with: openssl rand -hex 32
INTERNAL_JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Base64-encoded 32-byte AES-256 master key for encrypting token symmetric keys at rest.
# Generate with: openssl rand -base64 32
PAN_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# ─── Service URLs ─────────────────────────────────────────────────────────────
CORE_BANKING_BASE_URL=http://core-banking:8082

# ─── JVM ──────────────────────────────────────────────────────────────────────
SERVER_PORT=8081
