# ── DATABASE CREDENTIALS ──────────────────────────────────────────────────────
# Used by the Postgres container and both Spring Boot services.
MDES_DB_PASSWORD=changeme
CORE_DB_PASSWORD=changeme

# ── SERVICE AUTHENTICATION ────────────────────────────────────────────────────
# Shared secret used by MDES (FeignConfig) to mint internal JWTs and by
# Core Banking (JwtAuthenticationFilter) to validate them.
# MUST be >= 32 characters. Rotate before any external deployment.
INTERNAL_JWT_SECRET=change-me-in-production-min-32chars!!

# ── PAN ENCRYPTION KEY ────────────────────────────────────────────────────────
# AES-256 key (Base64-encoded 32 bytes). Used by Core Banking to encrypt the
# real PAN at rest in the cards table. MUST be rotated before production.
PAN_ENCRYPTION_KEY=Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24tMzJieXRlcyE=

# ── TSP RSA KEY PAIR ─────────────────────────────────────────────────────────
# RSA-2048 key pair. The TSP exposes the public key so Flutter can RSA-OAEP
# encrypt the PAN payload before transmission. The private key decrypts it.
# Leave as /app/certs/... when running inside Docker.
# The MDES service generates a self-signed pair on first startup if absent.
TSP_RSA_PRIVATE_KEY_PATH=/app/certs/tsp_private.pem
TSP_RSA_PUBLIC_KEY_PATH=/app/certs/tsp_public.pem

# ── URLS (for cross-service communication) ────────────────────────────────────
CORE_BANKING_BASE_URL=http://CORE-BANKING:8082
MDES_BASE_URL=http://localhost:8081
